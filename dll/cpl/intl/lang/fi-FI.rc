LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_GENERALPAGE DIALOGEX 0, 0, 246, 230
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Alueasetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Standardit ja muodot", -1, 5, 5, 234, 162
    LTEXT "Tämä asetus vaikuttaa siihen, miten jotkin ohjelmat muotoilevat numeroita, valuuttoja, päivämääriä ja kellonaikaa.", -1, 14, 17, 220, 25
    LTEXT "&Valitse kohde sen ominaisuuksien mukaan tai napsauta Mukauta valitaksesi omat muodot:", -1, 14, 42, 220, 22
    COMBOBOX IDC_LANGUAGELIST, 14, 66, 160, 160, CBS_DROPDOWNLIST | CBS_NOINTEGRALHEIGHT | CBS_SORT | WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_VSCROLL
    PUSHBUTTON "M&ukauta...", IDC_SETUP_BUTTON, 178, 65, 52, 14
    LTEXT "Esimerkit", -1, 14, 83, 70, 10
    LTEXT "Numero:", -1, 16, 96, 70, 10
    LTEXT "Valuutta:", -1, 16, 111, 70, 10
    LTEXT "Kellonaika:", -1, 16, 126, 70, 10
    LTEXT "Lyhyt päivämäärä:", -1, 16, 141, 70, 10
    LTEXT "Pitkä päivämäärä:", -1, 16, 156, 70, 10
    EDITTEXT IDC_NUMSAMPLE_EDIT, 89, 94, 140, 12, ES_READONLY | WS_CHILD | WS_VISIBLE | WS_GROUP | NOT WS_TABSTOP
    EDITTEXT IDC_MONEYSAMPLE_EDIT, 89, 109, 140, 12, ES_READONLY | WS_CHILD | WS_VISIBLE | WS_GROUP | NOT WS_TABSTOP
    EDITTEXT IDC_TIMESAMPLE_EDIT, 89, 124, 140, 12, ES_READONLY | WS_CHILD | WS_VISIBLE | WS_GROUP | NOT WS_TABSTOP
    EDITTEXT IDC_SHORTTIMESAMPLE_EDIT, 89, 139, 140, 12, ES_READONLY | WS_CHILD | WS_VISIBLE | WS_GROUP | NOT WS_TABSTOP
    EDITTEXT IDC_FULLTIMESAMPLE_EDIT, 89, 154, 140, 12, ES_READONLY | WS_CHILD | WS_VISIBLE | WS_GROUP | NOT WS_TABSTOP
    GROUPBOX "Maantieteellinen sijainti", -1, 5, 172, 234, 55
    LTEXT "Määri&tä sijaintisi, jotta palvelut voivat tarjota paikallisia tietoja, kuten uutisia ja säätiedotuksia.", -1, 14, 184, 210, 24
    COMBOBOX IDC_LOCATION_COMBO, 14, 207, 217, 160, CBS_DROPDOWNLIST | CBS_NOINTEGRALHEIGHT | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP | CBS_SORT
END

IDD_LANGUAGESPAGE DIALOGEX 0, 0, 246, 230
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Kielet"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Tekstinsyöttökielet ja palvelut", -1, 5, 5, 234, 52
    LTEXT "Näytä tai muuta kieli- tai tekstinsyöttötapoja napsauttamalla ""Asetukset..."".", -1, 12, 18, 155, 24
    PUSHBUTTON "&Asetukset...", IDC_DETAIL_BUTTON, 172, 24, 60, 14
    GROUPBOX "Kielten lisätuki", -1, 5, 62, 234, 82
    LTEXT "Useimmat kielet asennetaan oletuksena. Asenna lisäkieliä valitsemalla sopiva valintaruutu alta.", -1, 12, 74, 220, 18
    AUTOCHECKBOX "A&senna tiedostot monimutkaisille ja oikealta vasemmalle kirjoitettaville kielille", IDC_INST_FILES_FOR_RTOL_LANG, 12, 94, 215, 22, BS_MULTILINE | BS_TOP
    AUTOCHECKBOX "As&enna tiedostot itäaasialaisille kielille", IDC_INST_FILES_FOR_ASIAN, 12, 118, 215, 22, BS_MULTILINE | BS_TOP
END

IDD_ADVANCEDPAGE DIALOGEX 0, 0, 246, 230
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Lisäasetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Ei-Unicode-ohjelmien kieli", -1, 5, 5, 234, 90
    COMBOBOX IDC_LANGUAGE_COMBO, 14, 75, 217, 160, CBS_DROPDOWNLIST | CBS_NOINTEGRALHEIGHT | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP | CBS_SORT
    LTEXT "Tämä järjestelmäasetus mahdollistaa ei-Unicode-ohjelmille valikoiden ja valintaikkunoiden näyttämisen omalla kielellään. Se ei vaikuta Unicode-ohjelmiin, mutta koskee kaikkia tämän tietokoneen käyttäjiä.", -1, 14, 18, 223, 33
    LTEXT "&Valitse kieli, joka vastaa käyttämiesi ei-Unicode-ohjelmien kieliversiota:", -1, 14, 54, 223, 18
    GROUPBOX "&Koodisivun muunnostaulukot", -1, 5, 101, 234, 88
    CONTROL "", IDC_CONV_TABLES, "SysListView32", LVS_REPORT | LVS_SORTASCENDING | LVS_NOCOLUMNHEADER | WS_BORDER | WS_TABSTOP, 14, 114, 217, 70
    GROUPBOX "Oletuskäyttäjätilin asetukset", -1, 5, 193, 234, 32
    AUTOCHECKBOX "Käytä kaikkia asetuksia nykyiseen käyttäjätiliin ja &oletukseen", IDC_APPLY_CUR_USER_DEF_PROFILE, 12, 201, 220, 22, BS_MULTILINE | BS_TOP
END

IDD_NUMBERSPAGE DIALOGEX 0, 0, 246, 234
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Numerot"
FONT 8, "MS Shell Dlg"
BEGIN
