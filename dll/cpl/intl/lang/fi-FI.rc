h = tunti    m = minuutti    s = sekunti    t = am tai pm\n\
h = 12 tunnin muoto   H = 24 tunnin muoto\n\
hh, mm, ss = etunolla   h, m, s = ei etunollaa", -1, 13, 150, 214, 50, WS_CHILD | WS_VISIBLE | WS_GROUP
