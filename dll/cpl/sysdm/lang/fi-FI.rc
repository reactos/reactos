CAPTION "Lisenssi"
FONT 8, "MS Shell Dlg"
STYLE DS_SHELLFONT | WS_BORDER | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
BEGIN
    EDITTEXT IDC_LICENCEEDIT, 6, 3, 255, 131, WS_VSCROLL | ES_READONLY | ES_MULTILINE
    DEFPUSHBUTTON "OK", IDOK, 106, 140, 54, 15
END

IDD_VISUALEFFECTS DIALOGEX 6, 18, 227, 204
CAPTION "Visuaaliset tehosteet"
FONT 8, "MS Shell Dlg"
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
BEGIN
   LTEXT "Valitse asetukset, joita haluat käyttää ReactOSin ulkoasuun ja suorituskykyyn tällä tietokoneella.", IDC_STATIC, 7, 6, 208, 18
   CONTROL "", IDC_TREE, "SysTreeView32", TVS_LINESATROOT | TVS_DISABLEDRAGDROP | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP, 7, 32, 213, 168
END

IDD_ADVANCEDPERF DIALOGEX 6, 18, 227, 128
CAPTION "Lisäasetukset"
FONT 8, "MS Shell Dlg"
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
BEGIN
   GROUPBOX "Suorittimen ajoitus", IDC_STATIC, 7, 8, 213, 46
   LTEXT "Säädä parasta suorituskykyä varten:", IDC_STATIC, 14, 23, 199, 8
   AUTORADIOBUTTON "&Ohjelmat", IDC_CPUCLIENT, 14, 36, 75, 12
   AUTORADIOBUTTON "Tausta&pavelut", IDC_CPUSERVER, 96, 36, 85, 12
   GROUPBOX "Virtuaalimuisti", IDC_STATIC, 7, 60, 213, 57
   LTEXT "Sivutustiedosto on kiintolevyn alue, jota ReactOS käyttää kuin keskusmuistia.", IDC_STATIC, 14, 74, 199, 16
   PUSHBUTTON "&Vaihda...", IDC_CHANGESWAP, 163, 97, 50, 14
END

