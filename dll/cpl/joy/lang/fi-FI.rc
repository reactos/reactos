LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_PROPPAGEMAIN DIALOGEX 0, 0, 252, 205
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_CAPTION
EXSTYLE WS_EX_CONTEXTHELP
CAPTION "Peliohjaimet"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_CPLSYSTEM, -1, 7, 7, 20, 20
    LTEXT "Nämä asetukset auttavat määrittämään tietokoneeseen asennetut peliohjaimet.", -1, 33, 7, 214, 20, NOT WS_GROUP
    GROUPBOX "A&sennetut peliohjaimet", -1, 7, 34, 238, 117
    CONTROL "List1", IDC_CONTROLLER_LIST, "SysListView32", WS_BORDER | WS_GROUP | WS_TABSTOP | 0x0000808D, 14, 44, 224, 80
    PUSHBUTTON "&Lisää...", IDC_ADD_BUTTON, 35, 129, 65, 14
    PUSHBUTTON "&Poista", IDC_REMOVE_BUTTON, 104, 129, 65, 14, WS_DISABLED
    PUSHBUTTON "&Ominaisuudet", IDC_PROPERTIES_BUTTON, 173, 129, 65, 14, WS_DISABLED
    PUSHBUTTON "L&isäasetukset...", IDC_ADVANCED_BUTTON, 105, 157, 71, 14
    PUSHBUTTON "&Vianmääritys...", IDC_TROUBLESHOOT_BUTTON, 180, 157, 65, 14
    PUSHBUTTON "OK", IDOK, 195, 185, 50, 14
END

IDD_ADD DIALOGEX 0, 0, 265, 200
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_SETFOREGROUND | WS_POPUPWINDOW | WS_CAPTION
EXSTYLE WS_EX_CONTEXTHELP
CAPTION "Lisää peliohjain"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_CPLSYSTEM, -1, 8, 7, 20, 20
    LTEXT "Valitse peliohjain alla olevasta luettelosta ja napsauta OK. Jos ohjainta ei näy luettelossa, napsauta Mukautettu.", -1, 35, 7, 210, 33
    LTEXT "&Peliohjaimet:", -1, 8, 45, 126, 8
    LISTBOX IDC_GAME_CONTROLLERS_LIST, 7, 55, 251, 57, LBS_STANDARD | LBS_NOINTEGRALHEIGHT | LBS_WANTKEYBOARDINPUT | WS_HSCROLL | WS_TABSTOP
    AUTOCHECKBOX "Ota peräsin- ja poljin&toiminnot käyttöön", IDC_ENABLE_RUDDERS_CHECKBOX, 7, 114, 175, 10, WS_GROUP
    LTEXT "Peliohjain&portti:", -1, 7, 134, 55, 8, NOT WS_VISIBLE
    COMBOBOX IDC_GAME_PORT_COMBO, 7, 147, 140, 50, CBS_DROPDOWNLIST | CBS_SORT | NOT WS_VISIBLE | WS_VSCROLL
    PUSHBUTTON "&Mukautettu...", IDC_CUSTOM_BUTTON, 208, 147, 50, 14
    CONTROL "", -25525, "STATIC", SS_ETCHEDHORZ, 7, 170, 251, 1
    DEFPUSHBUTTON "OK", IDOK, 155, 179, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 208, 179, 50, 14
END

IDD_CUSTOM DIALOGEX 0, 0, 265, 183, 0
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_SETFOREGROUND | WS_POPUPWINDOW | WS_CAPTION
EXSTYLE WS_EX_CONTEXTHELP
CAPTION "Mukautettu peliohjain"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Erikoisominaisuudet", -1, 7, 7, 245, 52
    AUTORADIOBUTTON "&Joystick", IDC_JOYSTICK_RADIO, 17, 23, 55, 10
    AUTORADIOBUTTON "&Lentosauva tai -ohjain", IDC_FLIGHT_YOKE_RADIO, 132, 23, 110, 10
    AUTORADIOBUTTON "&Peliohjain", IDC_GAME_PAD_RADIO, 17, 40, 65, 10
    AUTORADIOBUTTON "&Autopeliohjain", IDC_RACE_CAR_RADIO, 132, 40, 110, 10
    GROUPBOX "&Akselit", -1, 7, 67, 116, 44, WS_GROUP
    COMBOBOX IDC_AXES_COMBO, 37, 79, 48, 50, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL
    AUTORADIOBUTTON "Peräsin/polkimet", IDC_RUDDER_PEDALS_RADIO, 14, 97, 70, 10, NOT WS_VISIBLE
    AUTORADIOBUTTON "Z-akseli", IDC_Z_AXIS_RADIO, 88, 97, 35, 10, NOT WS_VISIBLE
    GROUPBOX "&Painikkeet", -1, 137, 67, 116, 44
    COMBOBOX IDC_BUTTONS_COMBO, 178, 79, 48, 50, CBS_DROPDOWNLIST | CBS_AUTOHSCROLL | CBS_SORT | WS_VSCROLL, WS_EX_CLIENTEDGE
    AUTOCHECKBOX "Sisältää &suuntahattukytkimen", IDC_INC_POINT_CHECKBOX, 7, 123, 135, 10
    LTEXT "Oh&jaimen nimi:", -1, 7, 139, 200, 9
    EDITTEXT IDC_CONTROLLER_NAME_EDIT, 7, 150, 116, 15, ES_AUTOHSCROLL, WS_EX_CLIENTEDGE | WS_EX_STATICEDGE
    DEFPUSHBUTTON "OK", IDOK, 137, 150, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 203, 150, 50, 14
END

IDD_ADVANCED DIALOGEX 0, 0, 220, 86
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_CAPTION
EXSTYLE WS_EX_CONTEXTHELP
CAPTION "Lisäasetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_CPLSYSTEM, -1, 7, 24, 20, 20
    DEFPUSHBUTTON "OK", IDOK, 106, 65, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 163, 65, 50, 14
    LTEXT "Valitse laite, jota haluat käyttää vanhempien ohjelmien kanssa.", -1, 7, 7, 208, 10
    LTEXT "Ensisijainen laite:", -1, 34, 24, 70, 10
    COMBOBOX IDC_PREFERRED_DEV_COMBO, 34, 38, 179, 75, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL
END

STRINGTABLE
BEGIN
    IDS_CPLSYSTEMNAME "Peliohjaimet"
    IDS_CPLSYSTEMDESCRIPTION "Lisää, poista ja määritä peliohjainlaitteita, kuten joystickeja ja gamepadeja."
    IDS_CONTROLLER "Ohjain"
    IDS_STATUS "Tila"
    IDS_NONE "(Ei mitään)"
END
