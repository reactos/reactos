LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_THEMES DIALOGEX 0, 0, 246, 210
CAPTION "Teemat"
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Teema sisältää taustan sekä ääni-, kuvake- ja muita asetuksia, joilla voit mukauttaa tietokonettasi yhdellä napsautuksella.", IDC_STATIC, 5, 5, 235, 30
    LTEXT "&Teema:", IDC_STATIC, 5, 42, 55, 10
    COMBOBOX IDC_THEMES_COMBOBOX, 5, 52, 160, 300, CBS_HASSTRINGS | CBS_AUTOHSCROLL | CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Tallenna &nimellä...", IDC_THEMES_SAVE_AS, 170, 52, 70, 14
    PUSHBUTTON "&Poista", IDC_THEMES_DELETE, 170, 70, 70, 14
    CONTROL "", IDC_THEMES_PREVIEW, "STATIC", SS_BITMAP, 5, 90, 235, 115, WS_EX_CLIENTEDGE
END

IDD_BACKGROUND DIALOGEX 0, 0, 246, 210
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Tausta"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_BACKGROUND_PREVIEW, "Static", SS_OWNERDRAW, 70, 10, 105, 74
    CONTROL "", IDC_BACKGROUND_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_NOCOLUMNHEADER | LVS_SHAREIMAGELISTS | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 8, 104, 174, 86
    LTEXT "Valitse kuva työpöydän taustakuvaksi:", IDC_STATIC, 8, 93, 230, 9
    PUSHBUTTON "&Selaa...", IDC_BROWSE_BUTTON, 188, 104, 55, 15
    LTEXT "Sijoi&ttelu:", IDC_STATIC, 188, 128, 55, 9
    COMBOBOX IDC_PLACEMENT_COMBO, 188, 139, 55, 54, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "&Väri:", IDC_STATIC, 188, 156, 55, 9
    PUSHBUTTON " ", IDC_COLOR_BUTTON, 188, 167, 55, 15
    PUSHBUTTON "Mukauta &työpöytää...", IDC_DESKTOP_CUSTOM, 8, 194, 90, 15
END

IDD_SCREENSAVER DIALOGEX 0, 0, 246, 202
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Näytönsäästäjä"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_SCREENS_PREVIEW, "Static", SS_OWNERDRAW, 70, 10, 105, 74
    GROUPBOX "&Näytönsäästäjä", IDC_SCREENS_DUMMY, 8, 92, 230, 52
    COMBOBOX IDC_SCREENS_LIST, 14, 103, 100, 100, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Ase&tukset", IDC_SCREENS_SETTINGS, 120, 102, 50, 15, WS_GROUP
    PUSHBUTTON "E&sikatselu", IDC_SCREENS_TESTSC, 175, 102, 50, 15
    LTEXT "&Odota:", IDC_WAITTEXT, 14, 125, 22, 9
    EDITTEXT IDC_SCREENS_TIMEDELAY, 38, 123, 30, 13, ES_RIGHT | WS_GROUP
    CONTROL "", IDC_SCREENS_TIME, UPDOWN_CLASS, UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | WS_BORDER | WS_GROUP, 56, 123, 12, 13
    LTEXT "minuuttia", IDC_MINTEXT, 72, 125, 30, 9
    AUTOCHECKBOX "Kysy &salasanaa palattaessa", IDC_SCREENS_USEPASSCHK, 108, 121, 125, 14
    GROUPBOX "Näytön virransäästöominaisuudet", IDC_SCREENS_DUMMY2, 8, 150, 230, 41
    LTEXT "Säätääksesi näytön virta-asetuksia napsauta Virta-asetukset.", IDC_STATIC, 16, 161, 146, 27
    PUSHBUTTON "V&irta...", IDC_SCREENS_POWER_BUTTON, 167, 165, 61, 15
END

IDD_APPEARANCE DIALOGEX 0, 0, 246, 212
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Ulkoasu"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_APPEARANCE_PREVIEW, "PreviewWndClass", WS_VISIBLE | WS_BORDER, 7, 7, 232, 120
    LTEXT "&Visuaalinen tyyli:", IDC_STATIC, 7, 130, 104, 9
    COMBOBOX IDC_APPEARANCE_VISUAL_STYLE, 7, 140, 134, 90, CBS_DROPDOWNLIST | CBS_HASSTRINGS | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT "Vä&rimalli:", IDC_STATIC, 7, 157, 104, 9
    COMBOBOX IDC_APPEARANCE_COLORSCHEME, 7, 167, 134, 90, CBS_DROPDOWNLIST | CBS_HASSTRINGS | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT "&Fontin koko:", IDC_STATIC, 7, 184, 104, 9
    COMBOBOX IDC_APPEARANCE_SIZE, 7, 194, 134, 90, CBS_DROPDOWNLIST | CBS_HASSTRINGS | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "&Tehosteet...", IDC_APPEARANCE_EFFECTS, 165, 150, 74, 15
    PUSHBUTTON "L&isäasetukset...", IDC_APPEARANCE_ADVANCED, 165, 170, 74, 15
END

IDD_ADVAPPEARANCE DIALOGEX 0, 0, 250, 239
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_DLGMODALFRAME | WS_EX_WINDOWEDGE
CAPTION "Ulkoasun lisäasetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_APPEARANCE_PREVIEW, "PreviewWndClass", WS_VISIBLE | WS_BORDER, 7, 7, 232, 120
    LTEXT "Jos valitset muun teeman kuin ReactOS classic, seuraavat asetukset ylikirjoitetaan joitakin vanhoja ohjelmia lukuun ottamatta.", IDC_ADVAPPEARANCE_DISCLAIMER, 7, 133, 232, 30, BS_MULTILINE
    LTEXT "&Elementti:", 8, 5, 160, 50, 9
    COMBOBOX IDC_ADVAPPEARANCE_ELEMENT, 5, 170, 130, 90, CBS_DROPDOWNLIST | CBS_HASSTRINGS | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT "&Koko:", IDC_ADVAPPEARANCE_SIZE_T, 142, 160, 39, 9
    EDITTEXT IDC_ADVAPPEARANCE_SIZE_E, 142, 170, 26, 13, ES_RIGHT | WS_GROUP
    CONTROL "", IDC_ADVAPPEARANCE_SIZE_UD, UPDOWN_CLASS, UDS_AUTOBUDDY | WS_BORDER | WS_GROUP | UDS_ALIGNRIGHT | UDS_ARROWKEYS | UDS_SETBUDDYINT | WS_CHILD | WS_VISIBLE, 168, 170, 12, 13
    LTEXT "&1. väri:", IDC_ADVAPPEARANCE_COLOR1_T, 184, 160, 30, 9
    CHECKBOX "-", IDC_ADVAPPEARANCE_COLOR1_B, 184, 170, 28, 13, BS_PUSHLIKE | BS_BITMAP
    LTEXT "&2. väri:", IDC_ADVAPPEARANCE_COLOR2_T, 216, 160, 30, 9
    CHECKBOX "-", IDC_ADVAPPEARANCE_COLOR2_B, 216, 170, 28, 13, BS_PUSHLIKE | BS_BITMAP
    LTEXT "&Fontti:", IDC_ADVAPPEARANCE_FONT_T, 5, 190, 50, 9
    COMBOBOX IDC_ADVAPPEARANCE_FONT_C, 5, 200, 130, 90, CBS_DROPDOWN | CBS_HASSTRINGS | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT "Fontin ko&ko:", IDC_ADVAPPEARANCE_FONTSIZE_T, 142, 190, 39, 9
    COMBOBOX IDC_ADVAPPEARANCE_FONTSIZE_E, 142, 200, 38, 200, CBS_DROPDOWN | WS_VSCROLL
    LTEXT "Vä&ri:", IDC_ADVAPPEARANCE_FONTCOLOR_T, 184, 190, 28, 9
    CHECKBOX "", IDC_ADVAPPEARANCE_FONTCOLOR_B, 184, 200, 28, 13, BS_PUSHLIKE | BS_BITMAP
    AUTOCHECKBOX "B", IDC_ADVAPPEARANCE_FONTBOLD, 216, 200, 14, 13, BS_PUSHLIKE
    AUTOCHECKBOX "I ", IDC_ADVAPPEARANCE_FONTITALIC, 230, 200, 14, 13, BS_PUSHLIKE
    PUSHBUTTON "Peruuta", IDCANCEL, 191, 220, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 137, 220, 50, 14
END

IDD_EFFAPPEARANCE DIALOGEX 0, 0, 285, 185
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_DLGMODALFRAME | WS_EX_WINDOWEDGE
CAPTION "Tehosteet"
FONT 8, "MS Shell Dlg"
BEGIN
    AUTOCHECKBOX "&Käytä seuraavaa siirtymätehostetta valikoille ja työkaluvihjeille:", IDC_EFFAPPEARANCE_ANIMATION, 10, 5, 267, 19
    COMBOBOX IDC_EFFAPPEARANCE_ANIMATIONTYPE, 20, 25, 95, 19, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX "K&äytä seuraavaa menetelmää näytön fonttien reunan pehmennykseen:", IDC_EFFAPPEARANCE_SMOOTHING, 10, 42, 267, 19
    COMBOBOX IDC_EFFAPPEARANCE_SMOOTHINGTYPE, 20, 62, 95, 19, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX "K&äytä suuria kuvakkeita", IDC_EFFAPPEARANCE_LARGEICONS, 10, 80, 267, 19, WS_TABSTOP | WS_DISABLED
    AUTOCHECKBOX "Näytä varj&ot valikoiden alla", IDC_EFFAPPEARANCE_SETDROPSHADOW, 10, 95, 267, 19
    AUTOCHECKBOX "Näytä ikkunan &sisältö vedettäessä", IDC_EFFAPPEARANCE_DRAGFULLWINDOWS, 10, 110, 267, 19
    AUTOCHECKBOX "&Piilota alleviivatut kirjaimet näppäimistöselausta varten, kunnes painan Alt-näppäintä", IDC_EFFAPPEARANCE_KEYBOARDCUES, 10, 125, 267, 19
    AUTOCHECKBOX "Käytä &litteitä valikoita", IDC_EFFAPPEARANCE_FLATMENUS, 10, 140, 267, 19
    PUSHBUTTON "Peruuta", IDCANCEL, 226, 165, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 172, 165, 50, 14
END

IDD_SETTINGS DIALOGEX 0, 0, 246, 202
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Asetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_RESOLUTION_PREVIEW, "Static", SS_OWNERDRAW, 70, 10, 105, 74
    LTEXT "Raahaa näyttöjen kuvakkeita vastaamaan näyttöjen fyysistä järjestystä.", IDC_SETTINGS_MONTEXT, 3, 3, 240, 20
    CONTROL "", IDC_SETTINGS_MONSEL, "MONITORSELWNDCLASS", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 3, 23, 240, 82, WS_EX_CLIENTEDGE
    LTEXT "&Näyttö:", 1820, 3, 107, 70, 9
    LTEXT "<ei mikään>", IDC_SETTINGS_DEVICE, 3, 116, 224, 9
    GROUPBOX "&Näytön alue", 1818, 3, 127, 115, 43
    CONTROL "", IDC_SETTINGS_RESOLUTION, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP, 24, 137, 64, 17
    LTEXT "Vähemmän", 1815, 3, 157, 40, 9, NOT WS_GROUP
    RTEXT "Enemmän", 1816, 75, 157, 40, 9, NOT WS_GROUP
    CTEXT "", IDC_SETTINGS_RESOLUTION_TEXT, 10, 142, 100, 10, NOT WS_GROUP | NOT WS_VISIBLE
    GROUPBOX "&Värit", 1817, 125, 127, 115, 43
    COMBOBOX IDC_SETTINGS_BPP, 131, 137, 103, 80, CBS_DROPDOWNLIST | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    CONTROL "", IDC_SETTINGS_SPECTRUM, "Static", SS_OWNERDRAW | SS_SUNKEN, 131, 155, 103, 9
    PUSHBUTTON "L&isäasetukset...", IDC_SETTINGS_ADVANCED, 164, 174, 76, 15
END

