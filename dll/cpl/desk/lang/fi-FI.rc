IDR_PREVIEW_MENU MENU
BEGIN
    MENUITEM "Normaali", ID_MENU_NORMAL
    MENUITEM "Ei käytössä", ID_MENU_DISABLED
    MENUITEM "Valittu", ID_MENU_SELECTED
END

IDM_MONITOR_MENU MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Liitetty", ID_MENU_ATTACHED
        MENUITEM "&Ensisijainen", ID_MENU_PRIMARY
        MENUITEM SEPARATOR
        MENUITEM "&Tunnista", ID_MENU_IDENTIFY
        MENUITEM "O&minaisuudet", ID_MENU_PROPERTIES
    END
END

