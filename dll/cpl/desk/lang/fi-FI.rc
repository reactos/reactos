    AUTOCHECKBOX "&Oma tietokone", IDC_ICONS_MYCOMP, 14, 28, 100, 12
    AUTOCHECKBOX "&Internet-selain", IDC_ICONS_INTERNET, 116, 28, 100, 12
    CONTROL "", IDC_ICONS_LISTVIEW, "SysListView32", LVS_ICON | LVS_ALIGNLEFT | LVS_AUTOARRANGE | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP | WS_HSCROLL, 6, 60, 212, 56
