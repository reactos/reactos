IDD_ADVANCED_GENERAL DIALOGEX 0, 0, 253, 204
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Yleiset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Näyttö", -1, 7, 6, 237, 56, WS_GROUP
    LTEXT "&DPI-asetus:", -1, 14, 20, 222, 9
    COMBOBOX IDC_FONTSIZE_COMBO, 14, 30, 223, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "", IDC_FONTSIZE_CUSTOM, 14, 46, 223, 12
    GROUPBOX "Yhteensopivuus", -1, 7, 67, 237, 97
    LTEXT "Jotkin ohjelmat voivat toimia virheellisesti, jos et käynnistä tietokonetta uudelleen väriasetusten muutoksen jälkeen.\n\nKun vaihdan väriasetuksia:", -1, 12, 78, 228, 34
