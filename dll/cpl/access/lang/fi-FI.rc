    LTEXT "Suuren kontrastin pikanäppäin on:\nPaina vasen ALT + vasen VAIHTO + PRINT SCREEN.",
          -1, 12, 20, 222, 29
    AUTOCHECKBOX "&Käytä pikanäppäintä", IDC_CONTRAST_ACTIVATE_CHECK, 12, 49, 222, 14
    GROUPBOX "Suuren kontrastin teema", -1, 6, 83, 234, 44
    LTEXT "&Nykyinen teema:", -1, 12, 94, 222, 11
    COMBOBOX IDC_CONTRAST_COMBO, 12, 103, 222, 56,
             CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_VISIBLE | WS_TABSTOP
    DEFPUSHBUTTON "OK", IDOK, 135, 207, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 189, 207, 50, 14
