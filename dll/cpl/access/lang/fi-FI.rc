    LTEXT "Ohita Ohjauspaneelin näppäimistöasetukset:",
          -1, 12, 20, 222, 11
    AUTORADIOBUTTON "&Ei näppäimistön toistoa", IDC_REPEAT_NOREPEAT_RADIO, 12, 32, 210, 11, WS_GROUP
    AUTORADIOBUTTON "&Hidasta näppäimistön toistonopeutta", IDC_REPEAT_REPEAT_RADIO, 12, 45, 210, 11
    LTEXT "Toiston &viive:", -1, 24, 60, 60, 11
