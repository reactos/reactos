IDD_MOUSEKEYSOPTIONS DIALOGEX 0, 0, 246, 220
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Hiirinäppäinten asetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Pikanäppäin", -1, 6, 11, 234, 62
    LTEXT "Hiirinäppäinten pikanäppäin on:\nPaina vasen ALT + vasen VAIHTO + NUM LOCK.",
          -1, 12, 20, 222, 29
    AUTOCHECKBOX "&Käytä pikanäppäintä", IDC_MOUSEKEYS_ACTIVATE_CHECK, 12, 49, 222, 14
    GROUPBOX "Osoittimen nopeus", -1, 6, 83, 234, 83
    LTEXT "Huippunopeus:", -1, 12, 96, 54, 11
    LTEXT "Hidas", -1, 70, 96, 18, 11
    CONTROL "", IDC_MOUSEKEYS_SPEED_TRACK, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP,
            90, 94, 114, 20
    LTEXT "Suuri", -1, 208, 96, 18, 11
    LTEXT "Kiihtyvyys:", -1, 12, 123, 54, 11
    LTEXT "Hidas", -1, 70, 123, 18, 11
    CONTROL "", IDC_MOUSEKEYS_ACCEL_TRACK, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP,
            90, 121, 114, 20
    LTEXT "Nopea", -1, 208, 123, 18, 11
    AUTOCHECKBOX "Pidä CTRL painettuna nopeuttaaksesi ja VAIHTO hidastaaksesi", IDC_MOUSEKEYS_SPEED_CHECK,
                 12, 144, 222, 14
    LTEXT "Käytä hiirinäppäimiä, kun NUM LOCK on:", -1, 12, 171, 135, 11
    AUTORADIOBUTTON "P&äällä", IDC_MOUSEKEYS_ON_RADIO, 152, 171, 35, 11
    AUTORADIOBUTTON "P&ois", IDC_MOUSEKEYS_OFF_RADIO, 192, 171, 35, 11
    AUTOCHECKBOX "Näytä hiirinäppäinten &tila näytössä", IDC_MOUSEKEYS_STATUS_CHECK,
                 12, 186, 222, 14
    DEFPUSHBUTTON "OK", IDOK, 135, 207, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 189, 207, 50, 14
END

IDD_BOUNCEKEYSOPTIONS DIALOGEX 0, 0, 246, 220
