LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_PROPPAGE1 DIALOGEX 20, 40, 315, 104
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_OVERLAPPED | WS_CAPTION | WS_VISIBLE | WS_SYSMENU
CAPTION "Valitse lisensointitila"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "Asiakaslisensointitila", 100, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 4, 245, 94
    CONTROL "&Palvelinkohtainen. Samanaikaisten yhteyksien määrä:", 103, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 13, 38, 172, 10
    CONTROL "", 114, "EDIT", ES_LEFT | ES_AUTOHSCROLL | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP, 190, 37, 32, 12
    CONTROL "&Laite- tai käyttäjäkohtainen", 102, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 13, 79, 150, 10
    CONTROL "Tuote:", 105, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE, 13, 22, 31, 8
    CONTROL "", 106, "COMBOBOX", CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_TABSTOP, 49, 20, 185, 12
    CONTROL "Lisää l&isenssejä...", 111, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 30, 56, 75, 14
    CONTROL "P&oista lisenssejä...", 112, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 110, 56, 75, 14
    CONTROL "OK", 107, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 263, 7, 46, 14
    CONTROL "Peruuta", 108, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 263, 27, 46, 14
    CONTROL "&Ohje", 109, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 263, 48, 46, 14
    CONTROL "&Replikointi...", 110, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 263, 68, 46, 14
END

STRINGTABLE
BEGIN
    IDS_CPLNAME_1 "Lisenssien hallinta"
    IDS_CPLDESCRIPTION_1 "Määrittää ja hallitsee järjestelmän lisenssejä."
    IDS_REACTOS "ReactOS - Vapaa ohjelmisto"
END