LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

/* Dialogs */

IDD_USERS DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Käyttäjät"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_USERS_LIST, "SysListView32", LVS_REPORT | LVS_EDITLABELS | LVS_SINGLESEL |
            LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 7, 7, 238, 85, WS_EX_CLIENTEDGE
    PUSHBUTTON "L&isää...", IDC_USERS_ADD, 87, 98, 50, 14
    PUSHBUTTON "&Poista", IDC_USERS_REMOVE, 141, 98, 50, 14
    PUSHBUTTON "&Ominaisuudet", IDC_USERS_PROPERTIES, 195, 98, 50, 14
    AUTOCHECKBOX "Va&adi käyttäjänimi ja salasana järjestelmän käynnistyessä.", IDC_USERS_STARTUP_REQUIRE, 10, 118, 230, 14
    PUSHBUTTON "N&ollaa salasana...", IDC_USERS_RESET, 165, 200, 80, 14, WS_DISABLED
END

IDD_GROUPS DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Ryhmät"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_GROUPS_LIST, "SysListView32", LVS_REPORT | LVS_EDITLABELS | LVS_SINGLESEL |
            LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 7, 7, 238, 85, WS_EX_CLIENTEDGE
    PUSHBUTTON "L&isää...", IDC_GROUPS_ADD, 87, 98, 50, 14
    PUSHBUTTON "&Poista", IDC_GROUPS_REMOVE, 141, 98, 50, 14
    PUSHBUTTON "&Ominaisuudet", IDC_GROUPS_PROPERTIES, 195, 98, 50, 14
END

IDD_EXTRA DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Lisää"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Tämä tila on tyhjä.", IDC_STATIC, 66, 90, 112, 8
END

IDD_USER_GENERAL DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Yleiset"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "", IDC_USER_GENERAL_NAME, 7, 12, 112, 8
    LTEXT "Koko nimi:", -1, 7, 46, 63, 8
    EDITTEXT IDC_USER_GENERAL_FULL_NAME, 77, 43, 168, 13, ES_AUTOHSCROLL
    LTEXT "Kuvaus:", -1, 7, 64, 63, 8
    EDITTEXT IDC_USER_GENERAL_DESCRIPTION, 77, 61, 168, 13, ES_AUTOHSCROLL
    AUTOCHECKBOX "&Vaihda salasana seuraavalla kirjautumiskerralla", IDC_USER_GENERAL_FORCE_CHANGE, 7, 82, 238, 10
    AUTOCHECKBOX "Käyttäjä &ei voi vaihtaa salasanaa", IDC_USER_GENERAL_CANNOT_CHANGE, 7, 95, 238, 10
    AUTOCHECKBOX "&Salasana ei vanhene koskaan", IDC_USER_GENERAL_NEVER_EXPIRES, 7, 108, 238, 10
    AUTOCHECKBOX "&Tili on otettu pois käytöstä", IDC_USER_GENERAL_DISABLED, 7, 121, 238, 10
    AUTOCHECKBOX "Tili on &lukittu", IDC_USER_GENERAL_LOCKED, 7, 134, 238, 10
END

IDD_USER_MEMBERSHIP DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Jäsenyys"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Jäsenyys ryhmissä:", -1, 7, 7, 170, 8
    CONTROL "", IDC_USER_MEMBERSHIP_LIST, "SysListView32", LVS_REPORT | LVS_NOCOLUMNHEADER |
            LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 7, 18, 238, 173, WS_EX_CLIENTEDGE
    PUSHBUTTON "&Lisää...", IDC_USER_MEMBERSHIP_ADD, 7, 197, 50, 14
    PUSHBUTTON "&Poista", IDC_USER_MEMBERSHIP_REMOVE, 61, 197, 50, 14, WS_DISABLED
END

IDD_USER_PROFILE DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Profiili"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Käyttäjäprofiili", -1, 7, 7, 238, 54
    LTEXT "Profiilin polku:", -1, 16, 22, 55, 8
    EDITTEXT IDC_USER_PROFILE_PATH, 78, 19, 160, 13, ES_AUTOHSCROLL
    LTEXT "Kirjautumisskripti:", -1, 16, 40, 55, 8
    EDITTEXT IDC_USER_PROFILE_SCRIPT, 78, 37, 160, 13, ES_AUTOHSCROLL
    GROUPBOX "Kotihakemisto", -1, 7, 68, 238, 54
    AUTORADIOBUTTON "&Paikallinen polku:", IDC_USER_PROFILE_LOCAL, 16, 83, 60, 10
    AUTORADIOBUTTON "&Yhdistä:", IDC_USER_PROFILE_REMOTE, 16, 100, 60, 10
    EDITTEXT IDC_USER_PROFILE_LOCAL_PATH, 78, 81, 160, 13, ES_AUTOHSCROLL
    COMBOBOX IDC_USER_PROFILE_DRIVE, 78, 99, 30, 160, CBS_DROPDOWNLIST | CBS_SORT |
             WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_VSCROLL
    LTEXT "kohteeseen:", -1, 112, 101, 40, 8
    EDITTEXT IDC_USER_PROFILE_REMOTE_PATH, 154, 99, 84, 13, ES_AUTOHSCROLL
END

IDD_GROUP_GENERAL DIALOGEX 0, 0, 252, 223
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Yleiset"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "", IDC_GROUP_GENERAL_NAME, 7, 12, 112, 8
    LTEXT "Kuvaus:", -1, 7, 45, 46, 8
    EDITTEXT IDC_GROUP_GENERAL_DESCRIPTION, 65, 42, 180, 13, ES_AUTOHSCROLL
    LTEXT "Jäsenet:", -1, 7, 63, 45, 8
    CONTROL "", IDC_GROUP_GENERAL_MEMBERS, "SysListView32", LVS_REPORT | LVS_NOCOLUMNHEADER |
            LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 7, 74, 238, 117, WS_EX_CLIENTEDGE
    PUSHBUTTON "&Lisää...", IDC_GROUP_GENERAL_ADD, 7, 197, 50, 14
    PUSHBUTTON "&Poista", IDC_GROUP_GENERAL_REMOVE, 61, 197, 50, 14, WS_DISABLED
END

IDD_CHANGE_PASSWORD DIALOGEX 0, 0, 267, 74
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_SHELLFONT
CAPTION "Vaihda salasana"
FONT 8, "MS Shell Dlg"
BEGIN
    EDITTEXT IDC_EDIT_PASSWORD1, 107, 7, 153, 14, ES_AUTOHSCROLL | ES_PASSWORD
    RTEXT "Uusi salasana:", -1, 7, 10, 96, 8
    EDITTEXT IDC_EDIT_PASSWORD2, 107, 25, 153, 14, ES_AUTOHSCROLL | ES_PASSWORD
    RTEXT "Toista salasana:", -1, 7, 28, 96, 8
    DEFPUSHBUTTON "OK", IDOK, 156, 53, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 210, 53, 50, 14
END

IDD_USER_NEW DIALOGEX 0, 0, 267, 200
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_SHELLFONT
CAPTION "Uusi käyttäjä"
FONT 8, "MS Shell Dlg"
BEGIN
    EDITTEXT IDC_USER_NEW_NAME, 107, 7, 153, 14, ES_AUTOHSCROLL
    RTEXT "Käyttäjänimi:", -1, 7, 10, 96, 8
    EDITTEXT IDC_USER_NEW_FULL_NAME, 107, 25, 153, 14, ES_AUTOHSCROLL
    RTEXT "Koko nimi:", -1, 7, 28, 96, 8
    EDITTEXT IDC_USER_NEW_DESCRIPTION, 107, 43, 153, 14, ES_AUTOHSCROLL
    RTEXT "Kuvaus:", -1, 7, 46, 96, 8
    EDITTEXT IDC_USER_NEW_PASSWORD1, 107, 67, 153, 14, ES_AUTOHSCROLL | ES_PASSWORD
    RTEXT "Salasana:", -1, 7, 70, 96, 8
    EDITTEXT IDC_USER_NEW_PASSWORD2, 107, 85, 153, 14, ES_AUTOHSCROLL | ES_PASSWORD
    RTEXT "Toista salasana:", -1, 7, 88, 96, 8
    AUTOCHECKBOX "&Vaihda salasana seuraavalla kirjautumiskerralla", IDC_USER_NEW_FORCE_CHANGE, 7, 109, 250, 10
    AUTOCHECKBOX "Käyttäjä &ei voi vaihtaa salasanaa", IDC_USER_NEW_CANNOT_CHANGE, 7, 123, 250, 10, WS_DISABLED
    AUTOCHECKBOX "&Salasana ei vanhene koskaan", IDC_USER_NEW_NEVER_EXPIRES, 7, 137, 250, 10, WS_DISABLED
    AUTOCHECKBOX "&Tili on otettu pois käytöstä", IDC_USER_NEW_DISABLED, 7, 151, 250, 10
    DEFPUSHBUTTON "OK", IDOK, 156, 179, 50, 14, WS_DISABLED
    PUSHBUTTON "Peruuta", IDCANCEL, 210, 179, 50, 14
END

IDD_GROUP_NEW DIALOGEX 0, 0, 267, 74
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_SHELLFONT
CAPTION "Uusi ryhmä"
FONT 8, "MS Shell Dlg"
BEGIN
    EDITTEXT IDC_GROUP_NEW_NAME, 107, 7, 153, 14, ES_AUTOHSCROLL
    RTEXT "Ryhmän nimi:", -1, 7, 10, 96, 8
    EDITTEXT IDC_GROUP_NEW_DESCRIPTION, 107, 25, 153, 14, ES_AUTOHSCROLL
    RTEXT "Kuvaus:", -1, 7, 28, 96, 8
    DEFPUSHBUTTON "OK", IDOK, 156, 53, 50, 14, WS_DISABLED
    PUSHBUTTON "Peruuta", IDCANCEL, 210, 53, 50, 14
END

IDD_USER_ADD_MEMBERSHIP DIALOGEX 0, 0, 252, 223
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_SHELLFONT
CAPTION "Ryhmäjäsenyys"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Jäsenyys ryhmissä:", -1, 7, 7, 100, 8
    CONTROL "", IDC_USER_ADD_MEMBERSHIP_LIST, "SysListView32", LVS_REPORT |
            LVS_SHOWSELALWAYS | LVS_SORTASCENDING | WS_BORDER | WS_TABSTOP, 7, 18, 238, 173, WS_EX_CLIENTEDGE
    DEFPUSHBUTTON "OK", IDOK, 141, 197, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 195, 197, 50, 14
END

/* Menus */

IDM_POPUP_GROUP MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Uusi ryhmä...", IDM_GROUP_NEW
    END
    POPUP ""
    BEGIN
        MENUITEM "Lisää jäsen", IDM_GROUP_ADD_MEMBER, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "Poista", IDM_GROUP_DELETE
        MENUITEM "Nimeä uudelleen", IDM_GROUP_RENAME
        MENUITEM SEPARATOR
        MENUITEM "Ominaisuudet", IDM_GROUP_PROPERTIES
    END
END

IDM_POPUP_USER MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Uusi käyttäjä...", IDM_USER_NEW
    END
    POPUP ""
    BEGIN
        MENUITEM "Vaihda salasana...", IDM_USER_CHANGE_PASSWORD
        MENUITEM SEPARATOR
        MENUITEM "Poista", IDM_USER_DELETE
        MENUITEM "Nimeä uudelleen", IDM_USER_RENAME
        MENUITEM SEPARATOR
        MENUITEM "Ominaisuudet", IDM_USER_PROPERTIES
    END
END

/* Strings */

STRINGTABLE
BEGIN
    IDS_CPLNAME "Käyttäjätilit"
    IDS_CPLDESCRIPTION "Hallitsee käyttäjiä ja ryhmiä."
END

STRINGTABLE
BEGIN
    IDS_NAME "Nimi"
    IDS_FULLNAME "Koko nimi"
    IDS_DESCRIPTION "Kuvaus"
END