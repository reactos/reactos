IDD_SETUP1 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Asetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "ReactOS Audio", 10243, 7, 5, 213, 192
    ICON 4393, 10241, 26, 26, 20, 20
    LTEXT "Tietokone ei voi toistaa aanta, koska ReactOS Audio -palvelu ei ole kaytossa.", 10245, 60, 25, 150, 40
    AUTOCHECKBOX "&Ota ReactOS Audio kayttoon", 10253, 60, 68, 150, 9
    LTEXT "Huomautukset", 10246, 58, 87, 150, 11
    LTEXT "1. Sinun on oltava jarjestelmanvalvoja ottaaksesi taman palvelun kayttoon. Jos et ole kirjautunut jarjestelmanvalvojana, sinulta pyydetaan jarjestelmanvalvojan nimi ja salasana.", 10247, 60, 100, 150, 40
    LTEXT "2. ReactOS Audio -palvelun kayttoonoton jalkeen tietokone on kaynnistettava uudelleen.", 10248, 60, 140, 150, 40
END

