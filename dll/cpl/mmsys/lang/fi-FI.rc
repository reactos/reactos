LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_VOLUME DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Äänenvoimakkuus"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_CPLICON, IDI_CPLICON, 8, 5, 32, 32
    LTEXT "", IDC_DEVICE_NAME, 40, 10, 194, 20
    GROUPBOX "Laitteen äänenvoimakkuus", -1, 7, 30, 230, 100, WS_GROUP
    CONTROL "", IDC_MUTE_ICON, "Static", SS_ICON | WS_VISIBLE, 17, 45, 32, 32
    CONTROL "", IDC_VOLUME_TRACKBAR, "msctls_trackbar32", TBS_AUTOTICKS | TBS_BOTTOM | TBS_HORZ | WS_TABSTOP, 65, 45, 140, 20
    LTEXT "Hiljainen", IDC_VOLUME_LOW, 62, 66, 30, 9
    LTEXT "Voimakas", IDC_VOLUME_HIGH, 195, 66, 30, 9
    AUTOCHECKBOX "&Mykistä", IDC_MUTE_CHECKBOX, 50, 78, 140, 10
    AUTOCHECKBOX "Näytä äänenvoimakkuuden &kuvake tehtäväpalkissa", IDC_ICON_IN_TASKBAR, 50, 92, 190, 10
    PUSHBUTTON "L&isäasetukset...", IDC_ADVANCED_BTN, 150, 105, 75, 15
    GROUPBOX "Kaiutinasetukset", IDC_SPEAKER_SET_BTN, 7, 140, 230, 80, WS_GROUP
    CONTROL "", IDC_SPEAKIMG, "Static", SS_OWNERDRAW, 15, 155, 48, 45
    LTEXT "Muuta alla olevilla asetuksilla yksittäisten kaiuttimien äänenvoimakkuutta ja muita asetuksia.", -1, 70, 155, 150, 26
    PUSHBUTTON "&Kaiuttimien äänenvoimakkuus...", IDC_SPEAKER_VOL_BTN, 70, 185, 155, 15
    PUSHBUTTON "&Lisäasetukset...", IDC_ADVANCED2_BTN, 150, 202, 75, 15
END

IDD_SOUNDS DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Äänet"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Äänimalli on tapahtumiin liitetty äänijoukko ReactOSissa ja ohjelmissa. Voit valita olemassa olevan mallin tai tallentaa muokatun mallin.", -1, 8, 7, 230, 30
    LTEXT "Ääni&malli:", -1, 8, 42, 150, 9
    COMBOBOX IDC_SOUND_SCHEME, 8, 53, 230, 46, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Tallenna &nimellä...", IDC_SAVEAS_BTN, 134, 70, 50, 15
    PUSHBUTTON "&Poista", IDC_DELETE_BTN, 188, 70, 50, 15
    LTEXT "Muuta ääniä napsauttamalla ohjelmatapahtumaa alla olevasta luettelosta ja valitsemalla sille ääni. Voit tallentaa muutokset uutena äänimallina.", -1, 8, 90, 230, 27
    LTEXT "&Ohjelmatapahtumat:", -1, 8, 118, 150, 9
    CONTROL "", IDC_SCHEME_LIST, "SysTreeView32", TVS_DISABLEDRAGDROP | TVS_SHOWSELALWAYS | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP, 8, 130, 230, 60
    LTEXT "&Äänet:", IDC_TEXT_SOUND, 8, 194, 80, 9, WS_DISABLED
    COMBOBOX IDC_SOUND_LIST, 8, 205, 155, 146, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_TABSTOP | WS_DISABLED
    PUSHBUTTON "", IDC_PLAY_SOUND, 168, 205, 15, 15, WS_DISABLED | BS_ICON
    PUSHBUTTON "&Selaa...", IDC_BROWSE_SOUND, 188, 205, 50, 15, WS_DISABLED
END

IDD_AUDIO DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Ääni"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Äänen toisto", -1, 7, 7, 230, 60, WS_GROUP
    ICON IDI_CPLICON, IDI_CPLICON, 15, 20, 32, 32
    LTEXT "&Oletuslaite:", -1, 50, 20, 80, 9
    COMBOBOX IDC_DEVICE_PLAY_LIST, 50, 30, 180, 46, CBS_DROPDOWNLIST | WS_TABSTOP
    PUSHBUTTON "&Äänenvoimakkuus...", IDC_VOLUME1_BTN, 85, 47, 70, 15
    PUSHBUTTON "Lis&äasetukset...", IDC_ADV2_BTN, 160, 47, 70, 15
    GROUPBOX "Äänen tallennus", -1, 7, 75, 230, 60, WS_GROUP
    ICON IDI_MICROPHONE_ICON, IDI_MICROPHONE_ICON, 15, 88, 32, 32
    LTEXT "O&letuslaite:", -1, 50, 88, 80, 9
    COMBOBOX IDC_DEVICE_REC_LIST, 50, 98, 180, 46, CBS_DROPDOWNLIST | WS_TABSTOP
    PUSHBUTTON "Ä&änenvoimakkuus...", IDC_VOLUME2_BTN, 85, 115, 70, 15
    PUSHBUTTON "Lis&äasetukset...", IDC_ADV1_BTN, 160, 115, 70, 15
    GROUPBOX "MIDI-musiikin toisto", -1, 7, 145, 230, 60, WS_GROUP
    ICON IDI_MIDICON, IDI_MIDICON, 15, 158, 32, 32
    LTEXT "Oletuslai&te:", -1, 50, 158, 80, 9
    COMBOBOX IDC_DEVICE_MIDI_LIST, 50, 168, 180, 46, CBS_DROPDOWNLIST | WS_TABSTOP
    PUSHBUTTON "Äänenvoim&akkuus...", IDC_VOLUME3_BTN, 85, 185, 70, 15
    PUSHBUTTON "&Tietoja...", IDC_ADV3_BTN, 160, 185, 70, 15
    AUTOCHECKBOX "Käytä vain oletuslaitteita", IDC_DEFAULT_DEV_CHECKBOX, 7, 212, 140, 10, WS_GROUP | WS_TABSTOP
END

IDD_VOICE DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Puhe"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Nämä asetukset määrittävät valitun puheentoisto- tai puheentallennuslaitteen äänenvoimakkuuden ja lisäasetukset.", -1, 8, 7, 230, 30
    GROUPBOX "Puheentoisto", -1, 7, 37, 230, 60, WS_GROUP
    ICON IDI_CPLICON, IDI_CPLICON, 15, 50, 32, 32
    LTEXT "&Oletuslaite:", -1, 50, 50, 80, 9
    COMBOBOX IDC_DEVICE_VOICE_LIST, 50, 60, 180, 46, CBS_DROPDOWNLIST | WS_TABSTOP
    PUSHBUTTON "&Äänenvoimakkuus...", IDC_VOLUME4_BTN, 85, 77, 70, 15
    PUSHBUTTON "Lis&äasetukset...", IDC_ADV4_BTN, 160, 77, 70, 15
    GROUPBOX "Puheentallennus", -1, 7, 105, 230, 60, WS_GROUP
    ICON IDI_MICROPHONE_ICON, IDI_MICROPHONE_ICON, 15, 118, 32, 32
    LTEXT "O&letuslaite:", -1, 50, 118, 80, 9
    COMBOBOX IDC_DEVICE_VOICE_REC_LIST, 50, 128, 180, 46, CBS_DROPDOWNLIST | WS_TABSTOP
    PUSHBUTTON "Ä&änenvoimakkuus...", IDC_VOLUME5_BTN, 85, 145, 70, 15
    PUSHBUTTON "Lis&äasetukset...", IDC_ADV5_BTN, 160, 145, 70, 15
    PUSHBUTTON "&Testaa laitteisto...", IDC_TEST_HARDWARE, 160, 175, 70, 15, WS_GROUP | WS_TABSTOP
END

IDD_HARDWARE DIALOGEX 0, 0, 246, 228
STYLE DS_SHELLFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Laitteisto"
FONT 8, "MS Shell Dlg"
BEGIN
END

