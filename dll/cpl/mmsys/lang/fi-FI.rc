IDD_SETUP1 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Asetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "ReactOS Audio", 10243, 7, 5, 213, 192
    ICON 4393, 10241, 26, 26, 20, 20
    LTEXT "Tietokone ei voi toistaa ääntä, koska ReactOS Audio -palvelu ei ole käytössä.", 10245, 60, 25, 150, 40
    AUTOCHECKBOX "&Ota ReactOS Audio käyttöön", 10253, 60, 68, 150, 9
    LTEXT "Huomautukset", 10246, 58, 87, 150, 11
    LTEXT "1. Sinun on oltava järjestelmänvalvoja ottaaksesi tämän palvelun käyttöön. Jos et ole kirjautunut järjestelmänvalvojana, sinulta pyydetään järjestelmänvalvojan nimi ja salasana.", 10247, 60, 100, 150, 40
    LTEXT "2. ReactOS Audio -palvelun käyttöönoton jälkeen tietokone on käynnistettävä uudelleen.", 10248, 60, 140, 150, 40
END

