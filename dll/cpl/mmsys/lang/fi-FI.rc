IDD_SETUP2 DIALOGEX 0, 0, 227, 206
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_CAPTION
CAPTION "Asetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "ReactOS Audio", 10259, 7, 5, 213, 192
    ICON 4394, 10257, 25, 25, 20, 20
    LTEXT "ReactOS Audio -palvelu on nyt käytössä. Ääni ei kuitenkaan välttämättä toimi oikein ennen kuin käynnistät ReactOSin uudelleen. Jos haluat käynnistää nyt uudelleen, tallenna ensin työsi ja sulje kaikki ohjelmat.", 10261, 60, 25, 150, 50
    LTEXT "Käynnistä ReactOS uudelleen napsauttamalla OK.", 10262, 60, 75, 150, 20
    LTEXT "Jos valitset Peruuta, sinun on käynnistettävä myöhemmin uudelleen, jotta ReactOS Audio toimii oikein.", 10263, 60, 100, 150, 40
END

