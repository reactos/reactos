LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

IDD_ERRORDLG DIALOGEX 0, 0, 250, 95
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_VISIBLE | WS_CAPTION
CAPTION "Käyttäjäprofiili"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON IDI_USERENV, IDC_STATIC, 6, 10, 18, 20
    DEFPUSHBUTTON "OK", IDOK, 190, 10, 50, 14, BS_NOTIFY | WS_TABSTOP
    EDITTEXT IDC_ERRORDESC, 37, 10, 145, 66, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_BORDER | WS_TABSTOP
    RTEXT "Aikaa jäljellä:", IDC_TIMEOUTSTATIC, 172, 80, 54, 8
    LTEXT "", IDC_TIMEOUT, 230, 80, 12, 8
END

/* See also: dll/win32/shell32/lang */
STRINGTABLE
BEGIN
    IDS_PROFILEPATH "%SystemDrive%\\Documents and Settings"
    IDS_APPDATA "Ohjelmien tiedot"
    IDS_DESKTOP "Työpöytä"
    IDS_FAVORITES "Suosikit"
    IDS_MYDOCUMENTS "Omat tiedostot"
    IDS_NETHOOD "Lähiverkko"
    IDS_PRINTHOOD "Tulostimet"
    IDS_RECENT "Viimeksi käytetyt"
    IDS_SENDTO "Lähetä"
    IDS_TEMPLATES "Pohjat"
    IDS_STARTMENU "Käynnistä-valikko"
    IDS_PROGRAMS "Käynnistä-valikko\\Kaikki ohjelmat"
    IDS_STARTUP "Käynnistä-valikko\\Kaikki ohjelmat\\Käynnistys"
    IDS_LOCALSETTINGS "Paikalliset asetukset"
    IDS_LOCALAPPDATA "Paikalliset asetukset\\Ohjelmien tiedot"
    IDS_TEMP "Paikalliset asetukset\\Tilapäiset tiedostot" /* See also TEMP_DIR in boot/bootdata/hivedef.inf */
    IDS_CACHE "Paikalliset asetukset\\Väliaikaiset Internet-tiedostot"
    IDS_HISTORY "Paikalliset asetukset\\Historia"
    IDS_COOKIES "Evästeet"
END
