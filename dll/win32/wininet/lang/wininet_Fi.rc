LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

STRINGTABLE
{
  IDS_LANCONNECTION "LAN-yhteys"
  IDS_CERT_CA_INVALID   "Todistuksen on myöntänyt tuntematon tai epäluotettava julkaisija."
  IDS_CERT_DATE_INVALID "Todistuksen päivämäärä ei ole kelvollinen."
  IDS_CERT_CN_INVALID   "Todistuksen nimi ei vastaa sivustoa."
  IDS_CERT_ERRORS       "Tässä todistuksessa on vähintään yksi määrittämätön suojausongelma."
  IDS_CERT_SUBJECT      "Aihe"
  IDS_CERT_ISSUER       "Myöntäjä"
  IDS_CERT_EFFECTIVE    "Voimaantulopäivä"
  IDS_CERT_EXPIRATION   "Voimassaolon päättymispäivä"
  IDS_CERT_PROTOCOL     "Suojausprotokolla"
  IDS_CERT_SIGNATURE    "Allekirjoitustyyppi"
  IDS_CERT_ENCRYPTION   "Salaustyyppi"
  IDS_CERT_PRIVACY      "Yksityisyyden vahvuus"
  IDS_CERT_HIGH         "Korkea"
  IDS_CERT_LOW          "Matala"
  IDS_CERT_BITS         "bittiä"
}

IDD_PROXYDLG DIALOGEX 36, 24, 220, 146
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Anna verkon salasana"
FONT 8, "MS Shell Dlg"
{
 LTEXT "Anna käyttäjän nimi ja salasana:", -1, 6, 6, 210, 15
 LTEXT "Välityspalvelin", -1, 6, 26, 50, 18
 LTEXT "Alue", -1, 6, 46, 50, 18
 LTEXT "Käyttäjä", -1, 6, 66, 50, 18
 LTEXT "Salasana", -1, 6, 86, 50, 18
 LTEXT "", IDC_PROXY, 60, 26, 150, 14, 0
 LTEXT "", IDC_REALM, 60, 46, 150, 14, 0
 EDITTEXT IDC_USERNAME, 60, 66, 150, 14, ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP
 EDITTEXT IDC_PASSWORD, 60, 86, 150, 14, ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP | ES_PASSWORD
 CHECKBOX "&Tallenna tämä salasana (epäturvallinen)", IDC_SAVEPASSWORD,
           60, 106, 150, 12, BS_AUTOCHECKBOX | WS_GROUP | WS_TABSTOP
 PUSHBUTTON "OK", IDOK, 90, 126, 56, 14, WS_GROUP | WS_TABSTOP | BS_DEFPUSHBUTTON
 PUSHBUTTON "Peruuta", IDCANCEL, 154, 126, 56, 14, WS_GROUP | WS_TABSTOP
}

IDD_AUTHDLG DIALOGEX 36, 24, 220, 146
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Tunnistautuminen vaaditaan"
FONT 8, "MS Shell Dlg"
{
 LTEXT "Anna käyttäjänimesi ja salasanasi:", -1, 6, 6, 210, 15
 LTEXT "Palvelin", -1, 6, 26, 50, 18
 LTEXT "Tunnistealue", -1, 6, 46, 50, 18
 LTEXT "Käyttäjä", -1, 6, 66, 50, 18
 LTEXT "Salasana", -1, 6, 86, 50, 18
 LTEXT "", IDC_SERVER, 60, 26, 150, 14, 0
 LTEXT "", IDC_REALM, 60, 46, 150, 14, 0
 EDITTEXT IDC_USERNAME, 60, 66, 150, 14, ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP
 EDITTEXT IDC_PASSWORD, 60, 86, 150, 14, ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP | ES_PASSWORD
 CHECKBOX "&Tallenna tämä salasana (turvaton)", IDC_SAVEPASSWORD,
           60, 106, 150, 12, BS_AUTOCHECKBOX | WS_GROUP | WS_TABSTOP
 PUSHBUTTON "OK", IDOK, 90, 126, 56, 14, WS_GROUP | WS_TABSTOP | BS_DEFPUSHBUTTON
 PUSHBUTTON "Peruuta", IDCANCEL, 154, 126, 56, 14, WS_GROUP | WS_TABSTOP
}

IDD_INVCERTDLG DIALOGEX 3, 24, 250, 86
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Turvallisuusvaroitus"
FONT 8, "MS Shell Dlg"
{
 LTEXT "Tämän sivuston varmenteessa on ongelma.", -1, 40, 6, 200, 20
 LTEXT "", IDC_CERT_ERROR, 40, 26, 200, 20
 LTEXT "Haluatko jatkaa siitä huolimatta?", -1, 40, 46, 200, 20
 PUSHBUTTON "Kyllä", IDOK, 40, 66, 56, 14, WS_GROUP | WS_TABSTOP | BS_DEFPUSHBUTTON
 PUSHBUTTON "Ei", IDCANCEL, 100, 66, 56, 14, WS_GROUP | WS_TABSTOP
}
