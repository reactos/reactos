LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

ID_ACCEL ACCELERATORS
BEGIN
    "^A", CMD_SELECT_ALL
    "^C", CMD_COPY
    "^F", CMD_SEARCH
    "^G", CMD_GOTO
    "H", CMD_REPLACE, VIRTKEY, CONTROL
    "^N", CMD_NEW
    "N", CMD_NEW_WINDOW, VIRTKEY,CONTROL , SHIFT
    "^O", CMD_OPEN
    "^P", CMD_PRINT
    "^S", CMD_SAVE
    "^V", CMD_PASTE
    "^X", CMD_CUT
    "^Z", CMD_UNDO
    VK_F3, CMD_SEARCH_NEXT, VIRTKEY
    VK_F3, CMD_SEARCH_PREV, VIRTKEY, SHIFT
    VK_F5, CMD_TIME_DATE, VIRTKEY
END

MAIN_MENU MENU
BEGIN
    POPUP "&Tiedosto"
    BEGIN
        MENUITEM "&Uusi\tCtrl+N", CMD_NEW
        MENUITEM "&Uusi ikkuna\tCtrl+Shift+N", CMD_NEW_WINDOW
        MENUITEM "&Avaa\tCtrl+O", CMD_OPEN
        MENUITEM "Ta&lleta\tCtrl+S", CMD_SAVE
        MENUITEM "Talleta &nimellä...", CMD_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "&Sivun asetukset...", CMD_PAGE_SETUP
        MENUITEM "T&ulosta...\tCtrl+P", CMD_PRINT
        MENUITEM SEPARATOR
        MENUITEM "&Poistu", CMD_EXIT
    END
    POPUP "&Muokkaa"
    BEGIN
        MENUITEM "&Palauta\tCtrl+Z", CMD_UNDO
        MENUITEM SEPARATOR
        MENUITEM "&Leikkaa\tCtrl+X", CMD_CUT
        MENUITEM "&Kopioi\tCtrl+C", CMD_COPY
        MENUITEM "L&iitä\tCtrl+V", CMD_PASTE
        MENUITEM "P&oista\tDel", CMD_DELETE
        MENUITEM SEPARATOR
        MENUITEM "&Etsi...", CMD_SEARCH
        MENUITEM "Etsi &seuraava\tF3", CMD_SEARCH_NEXT
        MENUITEM "&Korvaa...\tCtrl+H", CMD_REPLACE
        MENUITEM "&Siirry...\tCtrl+G", CMD_GOTO
        MENUITEM SEPARATOR
        MENUITEM "&Valitse kaikki", CMD_SELECT_ALL
        MENUITEM "&Aika/Päivämäärä\tF5", CMD_TIME_DATE
    END
    POPUP "&Muotoile"
    BEGIN
        MENUITEM "Ka&tkaise pitkä rivi", CMD_WRAP
        MENUITEM "&Fontti...", CMD_FONT
    END
    POPUP "&Näytä"
    BEGIN
        MENUITEM "&Tilarivi", CMD_STATUSBAR
    END
    POPUP "&Apua"
    BEGIN
        MENUITEM "&Sisältö", CMD_HELP_CONTENTS
        MENUITEM SEPARATOR
        MENUITEM "&Tietoja Muistiosta", CMD_HELP_ABOUT_NOTEPAD
    END
END

/* Dialog 'Page setup' */
DIALOG_PAGESETUP DIALOGEX 0, 0, 365, 193
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU | DS_CONTEXTHELP
FONT 8, "MS Shell Dlg"
CAPTION "Sivun asetukset"
BEGIN
    GROUPBOX "Esikatselu", 0, 240, 6, 120, 153, BS_GROUPBOX
    CONTROL "", rct1, "Static", SS_WHITERECT, 260, 42, 80, 80
    CONTROL "", rct2, "Static", SS_GRAYRECT, 340, 46, 4, 80
    CONTROL "", rct3, "Static", SS_GRAYRECT, 264, 122, 80, 4
    GROUPBOX "Paperi", grp2, 8, 6, 224, 56, BS_GROUPBOX
    LTEXT "&Size:", stc2, 16, 22, 36, 8
    COMBOBOX cmb2, 64, 20, 160, 160, CBS_SIMPLE | CBS_DROPDOWN | CBS_SORT | WS_GROUP | WS_TABSTOP | WS_VSCROLL
    LTEXT "&Tray:", stc3, 16, 42, 36, 8
    COMBOBOX cmb3, 64, 40, 160, 160, CBS_SIMPLE | CBS_DROPDOWN | CBS_SORT | WS_GROUP | WS_TABSTOP | WS_VSCROLL
    GROUPBOX "Suunta", grp1, 8, 66, 64, 56, BS_GROUPBOX
    AUTORADIOBUTTON "&Pysty", rad1, 16, 80, 52, 12, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "&Vaaka", rad2, 16, 100, 52, 12
    GROUPBOX "Reunat", grp4, 80, 66, 152, 56, BS_GROUPBOX
    LTEXT "V&asen:", stc15, 88, 82, 30, 8
    EDITTEXT edt4, 119, 80, 36, 12, WS_TABSTOP | WS_GROUP | WS_BORDER
    LTEXT "&Oikea:", stc16, 159, 82, 30, 8
    EDITTEXT edt6, 190, 80, 36, 12, WS_TABSTOP | WS_GROUP | WS_BORDER
    LTEXT "&Ylä:", stc17, 88, 102, 30, 8
    EDITTEXT edt5, 119, 100, 36, 12, WS_TABSTOP | WS_GROUP | WS_BORDER
    LTEXT "&Ala:", stc18, 159, 102, 30, 8
    EDITTEXT edt7, 190, 100, 36, 12, WS_TABSTOP | WS_GROUP | WS_BORDER
    LTEXT "&Ylätunniste:", 0x140, 8, 132, 40, 15
    EDITTEXT 0x141, 58, 130, 173, 12, WS_BORDER | WS_TABSTOP | ES_AUTOHSCROLL
    LTEXT "&Alatunniste:", 0x142, 8, 149, 40, 15
    EDITTEXT 0x143, 58, 147, 173, 12, WS_BORDER | WS_TABSTOP | ES_AUTOHSCROLL
    PUSHBUTTON "&Ohje", IDHELP, 8, 170, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 198, 170, 50, 14, BS_PUSHBUTTON
    PUSHBUTTON "Peruuta", IDCANCEL, 254, 170, 50, 14
    PUSHBUTTON "&Tulostin...", psh3, 310, 170, 50, 14
END

/* Dialog 'Encoding' */
DIALOG_ENCODING DIALOGEX 0, 0, 256, 44
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD | WS_CLIPSIBLINGS | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Shell Dlg"
CAPTION "Merkistökoodaus"
BEGIN
    COMBOBOX ID_ENCODING, 124, 0, 125, 80, CBS_DROPDOWNLIST | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    LTEXT "Koodaus:", 0x155, 65, 2, 41, 12
    COMBOBOX ID_EOLN, 124, 18, 125, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Rivinvaihto:", 0x156, 65, 20, 41, 12
END

/* Dialog 'Go To' */
DIALOG_GOTO DIALOGEX 0, 0, 165, 50
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Shell Dlg"
CAPTION "Siirry riville"
BEGIN
    LTEXT "Rivinumero:", 0x155, 5, 12, 41, 12
    EDITTEXT ID_LINENUMBER, 54, 10, 106, 12, ES_NUMBER
    DEFPUSHBUTTON "OK", IDOK, 75, 30, 40, 15
    PUSHBUTTON "Peruuta", IDCANCEL, 120, 30, 40, 15
END

DIALOG_PRINTING DIALOG 0, 0, 160, 100
CAPTION "Tulostetaan"
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Shell Dlg"
BEGIN
    CTEXT "Tulostustyö alkaa...", IDC_PRINTING_STATUS, 5, 10, 150, 15
    CTEXT "(Filename)", IDC_PRINTING_FILENAME, 5, 35, 150, 15
    CTEXT "Sivu %u", IDC_PRINTING_PAGE, 5, 55, 150, 15
    PUSHBUTTON "Peruuta", IDCANCEL, 50, 75, 60, 20
END

