/* Menus */

IDR_MENU_SCIENTIFIC_1 MENU
BEGIN
    POPUP "&Chỉnh sửa"
    BEGIN
        MENUITEM "&Sao chép\tCtrl+C", IDM_EDIT_COPY
        MENUITEM "&Dán\tCtrl+V", IDM_EDIT_PASTE
    END
    POPUP "&Hiển thị"
    BEGIN
        MENUITEM "&Tiêu chuẩn", IDM_VIEW_STANDARD
        MENUITEM "&Khoa học", IDM_VIEW_SCIENTIFIC
        MENUITEM "&Chuyển đổi", IDM_VIEW_CONVERSION
        MENUITEM SEPARATOR
        MENUITEM "Thập &lục phân (Hex)\tF5", IDM_VIEW_HEX, CHECKED
        MENUITEM "&Thập phân (Dec)\tF6", IDM_VIEW_DEC, CHECKED
        MENUITEM "&Bát phân (Oct)\tF7", IDM_VIEW_OCT, CHECKED
        MENUITEM "&Nhị phân (Bin)\tF8", IDM_VIEW_BIN, CHECKED
        MENUITEM SEPARATOR
        MENUITEM "&Độ\tF2", IDM_VIEW_DEG, CHECKED
        MENUITEM "&Radian\tF3", IDM_VIEW_RAD, CHECKED
        MENUITEM "&Gradian\tF4", IDM_VIEW_GRAD, CHECKED
        MENUITEM SEPARATOR
        MENUITEM "&Nhóm các chữ số", IDM_VIEW_GROUP, CHECKED
    END
    POPUP "&Trợ giúp"
    BEGIN
        MENUITEM "Các chủ đề &trợ giúp", IDM_HELP_HELP
        MENUITEM SEPARATOR
        MENUITEM "&Giới thiệu về Máy tính ReactOS", IDM_HELP_ABOUT
    END
END

