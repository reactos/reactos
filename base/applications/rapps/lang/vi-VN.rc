LANGUAGE LANG_VIETNAMESE, SUBLANG_DEFAULT

IDR_MAINMENU MENU
BEGIN
    POPUP "&Tệp"
    BEGIN
        MENUITEM "&Cài đặt", ID_SETTINGS
        MENUITEM SEPARATOR
        MENUITEM "Th&oát", ID_EXIT
    END
    POPUP "&Chương trình"
    BEGIN
        MENUITEM "&Cài đặt\tCtrl+Enter", ID_INSTALL
        MENUITEM "&Gỡ cài đặt\tCtrl+Del", ID_UNINSTALL
        MENUITEM "&Thay đổi", ID_MODIFY
        MENUITEM SEPARATOR
        MENUITEM "&Xóa khỏi Registry", ID_REGREMOVE
        MENUITEM SEPARATOR
        MENUITEM "&Làm mới\tF5", ID_REFRESH
        MENUITEM SEPARATOR
        MENUITEM "Cập nhật cơ sở &dữ liệu\tCtrl+F5", ID_RESETDB
    END
    POPUP "Trợ &giúp"
    BEGIN
        MENUITEM "Trợ giúp\tF1", ID_HELP, GRAYED
        MENUITEM "&Giới thiệu", ID_ABOUT
    END
END

IDR_LINKMENU MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Mở liên kết trong trình duyệt", ID_OPEN_LINK
        MENUITEM "&Sao chép liên kết vào bộ nhớ tạm", ID_COPY_LINK
    END
END

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 250, 265
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Cài đặt"
FONT 8, "MS Shell Dlg"
BEGIN
    GROUPBOX "Chung", -1, 4, 2, 240, 61
    CONTROL "", IDC_GENERALLIST, "SysListView32", WS_TABSTOP | LVCHECKSTYLES, 15, 12, 219, 46, WS_EX_STATICEDGE
    GROUPBOX "Tải xuống", -1, 4, 65, 240, 51
    LTEXT "Thư mục tải xuống:", -1, 16, 75, 100, 9
    EDITTEXT IDC_DOWNLOAD_DIR_EDIT, 15, 86, 166, 12, WS_CHILD | WS_VISIBLE | WS_GROUP | ES_AUTOHSCROLL
    PUSHBUTTON "&Chọn", IDC_CHOOSE, 187, 85, 50, 14
    AUTOCHECKBOX "&Xóa bộ cài sau khi cài đặt xong", IDC_DEL_AFTER_INSTALL, 16, 100, 218, 12
    GROUPBOX "Nguồn phần mềm", -1, 4, 118, 240, 46
    AUTORADIOBUTTON "Dùng mặc định", IDC_SOURCE_DEFAULT, 15, 132, 74, 10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Nguồn chỉ định", IDC_USE_SOURCE, 15, 147, 74, 10
    EDITTEXT IDC_SOURCE_URL, 97, 147, 140, 12, ES_AUTOHSCROLL | WS_DISABLED
    GROUPBOX "Proxy", -1, 4, 166, 240, 76
    AUTORADIOBUTTON "Dùng cài đặt proxy hệ thống", IDC_PROXY_DEFAULT, 15, 180, 210, 10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Trực tiếp (Không proxy)", IDC_NO_PROXY, 15, 195, 210, 10
    AUTORADIOBUTTON "Proxy", IDC_USE_PROXY, 15, 210, 74, 10
    EDITTEXT IDC_PROXY_SERVER, 90, 210, 147, 12, ES_AUTOHSCROLL | WS_DISABLED
    LTEXT "Không proxy cho", -1, 26, 226, 64, 10
    EDITTEXT IDC_NO_PROXY_FOR, 90, 225, 147, 12, ES_AUTOHSCROLL | WS_DISABLED
    PUSHBUTTON "Mặc định", IDC_DEFAULT_SETTINGS, 8, 245, 60, 14, WS_GROUP | WS_TABSTOP
    DEFPUSHBUTTON "OK", IDOK, 116, 245, 60, 14
    PUSHBUTTON "Hủy bỏ", IDCANCEL, 181, 245, 60, 14
END

IDD_INSTALL_DIALOG DIALOGEX 0, 0, 216, 97
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Cài đặt chương trình"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "…", IDC_INSTALL_TEXT, 4, 5, 209, 35
    AUTORADIOBUTTON "&Cài đặt từ đĩa (CD hoặc DVD)", IDC_CD_INSTALL, 10, 46, 197, 11, WS_GROUP
    AUTORADIOBUTTON "&Tải xuống và cài đặt", IDC_DOWNLOAD_INSTALL, 10, 59, 197, 11, NOT WS_TABSTOP
    DEFPUSHBUTTON "OK", IDOK, 86, 78, 60, 14
    PUSHBUTTON "Hủy bỏ", IDCANCEL, 150, 78, 60, 14
END

IDD_DOWNLOAD_DIALOG DIALOGEX 0, 0, 220, 220
STYLE DS_SHELLFONT | DS_CENTER | WS_POPUPWINDOW | WS_CAPTION
CAPTION "Đang tải %ls…"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_DOWNLOAD_PROGRESS, "msctls_progress32", WS_BORDER | PBS_SMOOTH, 10, 10, 200, 12
    EDITTEXT IDC_DOWNLOAD_STATUS, 10, 28, 200, 22, ES_CENTER | ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_DISABLED | NOT WS_BORDER
    PUSHBUTTON "Hủy bỏ", IDCANCEL, 85, 53, 50, 15, WS_GROUP | WS_TABSTOP
END

