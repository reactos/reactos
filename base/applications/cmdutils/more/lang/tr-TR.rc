LANGUAGE LANG_TURKISH, SUBLANG_DEFAULT

STRINGTABLE
BEGIN
    IDS_USAGE "Ekranda veriyi sayfa sayfa görüntüler.\n\n\
  MORE < [Sürücü:][Yol]Dosya adı\n\
  Komut | MORE\n\
  MORE [Sürücü:][Yol]Dosya adı\n\n\
  [Sürücü:][Yol]Dosya adı    İçeriği görüntülenecek bir dosya.\n\
  Komut\t\t     Çıkışı görüntülenecek bir komut.\n\n\
  İstemde ""-- Sürdür --"" ile bir sonraki sayfayı göstermek için rastgele bir tuşa basabilirsiniz.\n"
    IDS_CONTINUE "-- Devam Et --"
    IDS_CONTINUE_PROGRESS "-- Devam Et (%%%d) --"
    IDS_FILE_ACCESS "%s dosyasına erişilemiyor.\n"
END
