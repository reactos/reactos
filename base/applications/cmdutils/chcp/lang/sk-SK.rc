LANGUAGE LANG_SLOVAK, SUBLANG_DEFAULT

STRINGTABLE
BEGIN
    STRING_CHCP_HELP "Zobrazí alebo nastaví kód aktívnej znakovej stránky.\n\n\
CHCP [nnn]\n\n\
  nnn   Špecifikuje kód aktívnej znakovej stránky.\n\n\
Použite CHCP bez parametra na zobrazenie kódu aktívnej znakovej stránky.\n"
    STRING_CHCP_ERROR1 "Aktívna znaková stránka: %u\n"
    STRING_CHCP_ERROR4 "Neplatná znaková stránka\n"
    STRING_ERROR_INVALID_PARAM_FORMAT "Neplatný formát parametra - %s\n"
END
