LANGUAGE LANG_CZECH, SUBLANG_DEFAULT

STRINGTABLE
BEGIN
    IDS_USAGE "\nVypíše současný název hostitele.\n\nhostname\n"
    IDS_NOSET "sethostname: Pro změnu názvu počítače otevřete záložku ""Název počítače""\nv nastaveních ""Systém"" v Ovládacích panelech.\nhostname -s není podporováno.\n"
    IDS_ERROR "Chyba: "
END
