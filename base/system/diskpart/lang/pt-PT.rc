LANGUAGE LANG_PORTUGUESE, SUBLANG_NEUTRAL

/* Basic application information */
STRINGTABLE
BEGIN
    IDS_APP_HEADER "Particionamento de disco do ReactOS"
    IDS_APP_USAGE "\nInterpretador de particionamento de disco.\n\n\
Utilização: DISKPART [/S Nome de ficheiro] [/T T limite] [/?]\n\n\
/S Nome de ficheiro\tExecuta o script fornecido..\n\
/T T limite\tTempo limite em segundos para evitar sobreposição na utilização do DiskPart.\n\
/?\t\tMostrar esta mensagem de ajuda.\n\n"
    IDS_APP_LICENSE "Licenciado sob GNU GPLv2\n"
    IDS_APP_CURR_COMPUTER "Nome do computador: %s\n\n"
    IDS_APP_LEAVING "\nA sair do particionamento de disco...\n"
    IDS_APP_PROMPT "DISKPART> "
END

/* ACTIVE command strings */
STRINGTABLE
BEGIN
    IDS_ACTIVE_FAIL "\nO DiskPart não conseguiu marcar a partição como activa.\nCertifique-se de que a partição é válida.\n"
    IDS_ACTIVE_SUCCESS "\nO DiskPart marcou a partição actual como activa.\n"
    IDS_ACTIVE_ALREADY "\nA partição actual já está marcada como activa.\n"
    IDS_ACTIVE_NO_MBR "\nO disco seleccionado não é um disco MBR.\nO comando ACTIVE só pode ser utilizado num disco MBR.\n"
END

/* ASSIGN command strings */
STRINGTABLE
BEGIN
    IDS_ASSIGN_FAIL "\nO DiskPart não conseguiu atribuir uma letra de unidade ou um ponto de montagem.\nCertifique-se de que a letra da unidade ou o ponto de montagem é válido.\n"
    IDS_ASSIGN_SUCCESS "\nO DiskPart atribuiu com sucesso a letra de unidade ou o ponto de montagem.\n"
    IDS_ASSIGN_ALREADY_ASSIGNED "\nA letra especificada já foi atribuída a esta unidade.\n"
    IDS_ASSIGN_INVALID_LETTER "\nA letra que especificou não é uma letra de volume válida.\n"
    IDS_ASSIGN_NO_MORE_LETTER "\nNão há letras de unidade livres para atribuir a este volume. Liberte uma letra de unidade e tente novamente.\n"
    IDS_ASSIGN_SYSTEM_VOLUME "\nO DiskPart não consegue reatribuir a letra de unidade num volume de sistema, de iniciação ou de ficheiro de paginação.\n"
END

/* AUTOMOUNT command strings */
STRINGTABLE
BEGIN
    IDS_AUTOMOUNT_ENABLED "\nActivada a montagem automática de novos volumes.\n"
    IDS_AUTOMOUNT_DISABLED "\nA montagem automática de novos volumes está desactivada.\n"
    IDS_AUTOMOUNT_SCRUBBED "\nO DiskPart limpou com sucesso as definições do ponto de montagem no sistema.\n"
END

STRINGTABLE
BEGIN
    IDS_CLEAN_FAIL "\nO DiskPart não conseguiu limpar o disco.\nOs dados neste disco podem ser irrecuperáveis.\n"
    IDS_CLEAN_SUCCESS "\nO DiskPart conseguiu limpar o disco.\n"
    IDS_CLEAN_SYSTEM "\nO disco seleccionado é necessário para o funcionamento do seu computador e não pode ser formatado.\n"
END

STRINGTABLE
BEGIN
    IDS_CONVERT_GPT_ALREADY "\nO disco seleccionado não pode ser convertido porque já está formatado em GPT.\n"
    IDS_CONVERT_GPT_NOT_EMPTY "\nO disco seleccionado não pode ser convertido para o formato GPT. Seleccione um disco MBR vazio para conversão.\n"
    IDS_CONVERT_GPT_SUCCESS "\nO disco seleccionado foi convertido com sucesso para o formato GPT.\n"
    IDS_CONVERT_MBR_ALREADY "\nO disco seleccionado não pode ser convertido porque já foi formatado em MBR.\n"
    IDS_CONVERT_MBR_NOT_EMPTY "\nO disco seleccionado não pode ser convertido para o formato MBR.\nSeleccione um disco GPT vazio para conversão.\n"
    IDS_CONVERT_MBR_SUCCESS "\nO disco seleccionado foi convertido com sucesso para o formato MBR.\n"
END

STRINGTABLE
BEGIN
    IDS_CREATE_PARTITION_FAIL "\nO DiskPart não conseguiu criar a partição especificada.\n"
    IDS_CREATE_PARTITION_SUCCESS "\nO DiskPart conseguiu criar a partição especificada.\n"
    IDS_CREATE_PARTITION_INVALID_STYLE "\nNão é possível criar partições lógicas ou estendidas num disco GPT.\nEm vez disso, crie uma partição primária num disco GPT.\n"
END

STRINGTABLE
BEGIN
    IDS_DELETE_PARTITION_FAIL "\nO DiskPart não conseguiu eliminar a partição seleccionada.\nCertifique-se de que a partição seleccionada é válida para eliminação.\n"
    IDS_DELETE_PARTITION_SUCCESS "\nO DiskPart eliminou com sucesso a partição seleccionada.\n"
    IDS_DELETE_PARTITION_SYSTEM "\nA partição seleccionada pode ser necessária para o funcionamento do seu computador e não deve ser eliminada.\n"
END

