/* Error Strings */

STRINGTABLE
BEGIN
    IDS_ERROR_INVALID_INSTALLDIR_CHAR_TITLE "Caracter inválido"
    IDS_ERROR_INVALID_INSTALLDIR_CHAR "Os caracteres válidos são:\n\
alfanuméricos (a-z, A-Z, 0-9), e\n . \\ - _\n\
Espaços não são permitidos."

    IDS_ERROR_DIRECTORY_NAME_TITLE "Caminho de instalação inválido"
    IDS_ERROR_DIRECTORY_NAME "O caminho de instalação do ReactOS deve seguir o esquema de nomenclatura do DOS 8.3., \
e conter apenas letras, dígitos, hífens e pontos. Espaços não são permitidos."

    IDS_ERROR_CREATE_PARTITION_TITLE "Criar partição"
    IDS_ERROR_CREATE_PARTITION "Falha ao criar uma nova partição."

    IDS_WARN_DELETE_PARTITION_TITLE "Apagar partição?"
    IDS_WARN_DELETE_PARTITION "Pretende eliminar a partição seleccionada?"
    IDS_WARN_DELETE_MBR_EXTENDED_PARTITION "Pretende eliminar a partição estendida seleccionada e TODAS as partições lógicas associadas?"

    IDS_ERROR_WRITE_PTABLE "A instalação falhou ao gravar a tabela de partições."

    IDS_ERROR_SYSTEM_PARTITION "O programa de instalação do ReactOS não encontrou uma partição compatível\n\
no seu sistema ou não conseguiu criar uma nova. Sem uma partição compatível,\n\
o programa de instalação não poderá instalar o ReactOS.\n\
Clique em OK para voltar à lista de selecção de partições."

    IDS_ERROR_FORMAT_UNRECOGNIZED_VOLUME "Volume não reconhecido ao tentar formatar a partição."

    IDS_ERROR_COULD_NOT_FORMAT "O programa de instalação não consegue formatar a partição em %s.\n\
\nClique em OK para continuar a instalação.\
\nClique em CANCELAR para sair da instalação."

    IDS_ERROR_FORMATTING_PARTITION "A instalação não conseguiu formatar a partição:\n %s\n"

    IDS_ERROR_COULD_NOT_CHECK "O programa de instalação não conseguiu verificar a partição formatada em %s.\n\
\nClique em OK para continuar a instalação.\
\nClique em CANCELAR para sair da instalação."

    IDS_ERROR_CHECKING_PARTITION "O ChkDsk detectou alguns erros no disco.\n(Status 0x%08lx)."

    IDS_ERROR_WRITE_BOOT "A instalação falhou ao tentar instalar o código de arranque %s na partição do sistema."
    IDS_ERROR_INSTALL_BOOTCODE "A instalação falhou ao tentar instalar o código de arranque %s no disco de arranque."
    IDS_ERROR_INSTALL_BOOTCODE_REMOVABLE "A instalação do código de arranque no suporte removível falhou."
    IDS_ERROR_BOOTLDR_ARCH_UNSUPPORTED "O programa de instalação não suporta a instalação do programa de arranque no computador que está a utilizar.\
\nClique em OK para continuar mesmo assim."
    IDS_ERROR_BOOTLDR_FAILED "A instalação não conseguiu instalar o programa de arranque. (Status 0x%08lx)."
END
