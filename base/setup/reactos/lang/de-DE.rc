BEGIN
    IDS_INSTALLATION_NAME "Name"
    IDS_INSTALLATION_PATH "Installation Path"
    IDS_INSTALLATION_VENDOR "Vendor Name"
END

STRINGTABLE
BEGIN
    IDS_PARTITION_NAME "Name"
    IDS_PARTITION_TYPE "Type"
    IDS_PARTITION_SIZE "Size"
    IDS_PARTITION_STATUS "Status"
END
