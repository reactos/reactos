LANGUAGE LANG_FINNISH, SUBLANG_DEFAULT

/* Dialogs */

IDD_STARTPAGE DIALOGEX 0, 0, 317, 193
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Tervetuloa ReactOS-asennusohjelmaan", IDC_STARTTITLE, 115, 8, 195, 24
    LTEXT "Tämä ohjattu toiminto asentaa tai päivittää ReactOSin tietokoneeseesi ja valmistelee asennuksen toisen vaiheen.", IDC_STATIC, 115, 40, 195, 27
////
    GROUPBOX " TÄRKEÄÄ TIETOA ", IDC_WARNTEXT1, 115, 70, 195, 90, BS_CENTER
    LTEXT "ReactOS on alfa-vaiheessa: kaikki ominaisuudet eivät vielä ole käytettävissä ja kehitystyö on voimakasta. Ohjelmaa suositellaan käytettäväksi vain arviointiin ja testaukseen, ei päivittäisenä käyttöjärjestelmänä.\n\nSe saattaa vioittaa tietojasi tai vahingoittaa laitteistoasi.", IDC_WARNTEXT2, 120, 82, 185, 52
    LTEXT "Varmuuskopioi tietosi tai kokeile järjestelmää toisella tietokoneella, jos aiot käyttää ReactOSia oikealla laitteistolla.", IDC_WARNTEXT3, 120, 134, 185, 24
////
    LTEXT "Jatka asennusta valitsemalla Seuraava.", IDC_STATIC, 115, 169, 195, 17
END

IDD_TYPEPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    AUTORADIOBUTTON "&Asenna ReactOS", IDC_INSTALL, 7, 20, 277, 10, WS_GROUP | WS_TABSTOP
    LTEXT "Asenna uusi ReactOS-kopio. Tämä vaihtoehto ei säilytä tiedostojasi, asetuksiasi eikä ohjelmiasi. Voit muuttaa levyjä ja osioita.", IDC_INSTALLTEXT, 19, 36, 279, 27, NOT WS_GROUP
    AUTORADIOBUTTON "&Päivitä tai korjaa ReactOS", IDC_UPDATE, 7, 80, 277, 10
    LTEXT "Päivitä tai korjaa asennettu ReactOS-kopio. Tämä vaihtoehto säilyttää tiedostosi, asetuksesi ja ohjelmasi. Tämä vaihtoehto on käytettävissä vain, jos ReactOS on jo asennettu tähän tietokoneeseen.", IDC_UPDATETEXT, 19, 96, 279, 27, NOT WS_GROUP
END

IDD_UPDATEREPAIRPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Asennusohjelma voi päivittää jonkin alla luetelluista ReactOS-asennuksista tai yrittää korjata vioittuneen asennuksen.", IDC_STATIC, 6, 6, 303, 18
    CONTROL "", IDC_NTOSLIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_ALIGNLEFT | WS_BORDER | WS_TABSTOP, 6, 30, 303, 90
    PUSHBUTTON "&Älä päivitä", IDC_SKIPUPGRADE, 230, 128, 80, 14
    LTEXT "Jatka valitun käyttöjärjestelmän päivitystä valitsemalla Seuraava, tai tee uusi asennus valitsemalla 'Älä päivitä'.", IDC_STATIC, 7, 124, 222, 16
END

IDD_DEVICEPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Tietokone:", IDC_STATIC, 20, 15, 80, 10
    COMBOBOX IDC_COMPUTER, 100, 15, 180, 80, WS_VSCROLL | WS_TABSTOP | CBS_DROPDOWNLIST
    LTEXT "Näyttö:", IDC_STATIC, 20, 35, 80, 10
    COMBOBOX IDC_DISPLAY, 100, 35, 180, 80, WS_VSCROLL | WS_TABSTOP | CBS_DROPDOWNLIST
    LTEXT "Näppäimistö:", IDC_STATIC, 20, 55, 80, 10
    COMBOBOX IDC_KEYBOARD, 100, 55, 180, 80, WS_VSCROLL | WS_TABSTOP | CBS_DROPDOWNLIST
    LTEXT "Jatka asennusta asennuslaitteeseen valitsemalla Seuraava.", IDC_STATIC, 7, 128, 297, 8
END

IDD_DRIVEPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_PARTITION, "SysTreeList32", WS_BORDER | WS_VISIBLE | WS_TABSTOP | LVS_REPORT | LVS_SINGLESEL, 7, 7, 303, 112
    PUSHBUTTON "&Valmistele", IDC_INITDISK, 7, 122, 50, 14
    PUSHBUTTON "&Luo", IDC_PARTCREATE, 7, 122, 50, 14
    PUSHBUTTON "&Alusta", IDC_PARTFORMAT, 7, 122, 50, 14
    PUSHBUTTON "&Poista", IDC_PARTDELETE, 63, 122, 50, 14
    PUSHBUTTON "A&juri", IDC_DEVICEDRIVER, 174, 122, 50, 14, WS_DISABLED
    PUSHBUTTON "&Lisäasetukset...", IDC_PARTMOREOPTS, 230, 122, 80, 14
    // LTEXT "Click Next to check the summary.", IDC_STATIC, 7, 128, 277, 8
    LTEXT "Jatka tarkistamalla yhteenveto valitsemalla Seuraava.", IDC_STATIC, 7, 128, 277, 8
END

IDD_PARTITION DIALOGEX 0, 0, 200, 120
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Luo ja alusta osio"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "&Koko:", IDC_STATIC, 7, 9, 70, 9
    EDITTEXT IDC_EDIT_PARTSIZE, 82, 7, 47, 13, ES_RIGHT | ES_NUMBER | WS_GROUP
    CONTROL "", IDC_UPDOWN_PARTSIZE, UPDOWN_CLASS, UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | WS_GROUP, 120, 7, 9, 13
    LTEXT "Mt", IDC_UNIT, 134, 9, 14, 9
    AUTOCHECKBOX "&Laajennettu osio", IDC_CHECK_MBREXTPART, 7, 22, 180, 14
    LTEXT "&Tiedostojärjestelmä:", IDC_FS_STATIC, 7, 46, 70, 9
    COMBOBOX IDC_FSTYPE, 82, 44, 100, 50, CBS_DROPDOWNLIST | WS_TABSTOP
    AUTOCHECKBOX "&Pikamuotoilu", IDC_CHECK_QUICKFMT, 7, 59, 180, 14
    PUSHBUTTON "OK", IDOK, 88, 98, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 143, 98, 50, 14
END

IDD_FORMAT DIALOGEX 0, 0, 200, 83
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Alusta osio"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "&Tiedostojärjestelmä:", IDC_FS_STATIC, 7, 9, 70, 9
    COMBOBOX IDC_FSTYPE, 82, 7, 100, 50, CBS_DROPDOWNLIST | WS_TABSTOP
    AUTOCHECKBOX "&Pikamuotoilu", IDC_CHECK_QUICKFMT, 7, 22, 180, 14
    PUSHBUTTON "OK", IDOK, 88, 61, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 143, 61, 50, 14
END

IDD_ADVANCED_INSTALL DIALOGEX 0, 0, 305, 135
STYLE DS_SHELLFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Asennuksen lisäasetukset"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Valitse &hakemisto, johon haluat asentaa ReactOSin:", IDC_STATIC, 7, 9, 291, 10
    EDITTEXT IDC_PATH, 7, 23, 291, 13
    GROUPBOX "Käynnistyslatain", IDC_STATIC, 7, 45, 291, 60
    LTEXT "Valitse sijainti, johon FreeLoader-käynnistyslatain asennetaan.\n\nOletusarvoisesti se asennetaan käynnistyslevyn järjestelmäosioon (BIOS-pohjaisissa tietokoneissa joko Master Boot Recordiin tai Volume Boot Recordiin).", IDC_STATIC, 13, 57, 279, 44
    COMBOBOX IDC_INSTFREELDR, 150, 58, 142, 45, WS_VSCROLL | WS_TABSTOP | CBS_DROPDOWNLIST
    DEFPUSHBUTTON "OK", IDOK, 193, 113, 50, 14
    PUSHBUTTON "Peruuta", IDCANCEL, 248, 113, 50, 14
END

IDD_SUMMARYPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Asennustyyppi:", IDC_STATIC, 18, 5, 74, 11
    EDITTEXT IDC_INSTALLTYPE, 95, 4, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Asennuslähde:", IDC_STATIC, 18, 17, 74, 11
    EDITTEXT IDC_INSTALLSOURCE, 95, 16, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Arkkitehtuuri:", IDC_STATIC, 18, 29, 74, 11
    EDITTEXT IDC_ARCHITECTURE, 95, 28, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Tietokone:", IDC_STATIC, 18, 41, 74, 11
    EDITTEXT IDC_COMPUTER, 95, 40, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Näyttö:", IDC_STATIC, 18, 53, 74, 11
    EDITTEXT IDC_DISPLAY, 95, 52, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Näppäimistö:", IDC_STATIC, 18, 65, 74, 11
    EDITTEXT IDC_KEYBOARD, 95, 64, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Kohdelevy:", IDC_STATIC, 18, 77, 74, 11
    EDITTEXT IDC_DESTDRIVE, 95, 76, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    LTEXT "Kohdehakemisto:", IDC_STATIC, 18, 89, 74, 11
    EDITTEXT IDC_PATH, 95, 88, 210, 13, ES_READONLY | ES_AUTOHSCROLL | WS_VISIBLE | NOT WS_BORDER | NOT WS_TABSTOP
    AUTOCHECKBOX "Vahvistan, että asennusasetukset ovat oikein. Hyväksyn myös sen, että ReactOS on alfa-vaiheen ohjelmisto ja saattaa vioittaa tietojani.", IDC_CONFIRM_INSTALL, 7, 104, 303, 18, BS_MULTILINE | WS_TABSTOP
    LTEXT "Vahvista, että kaikki asennusasetukset ovat oikein, ja valitse sitten Asenna käynnistääksesi asennuksen.", IDC_STATIC, 7, 124, 303, 18
END

IDD_PROCESSPAGE DIALOGEX 0, 0, 317, 143
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Asennetaan tiedostoja...", IDC_ACTIVITY, 20, 50, 277, 10
    LTEXT "test.txt", IDC_ITEM, 30, 80, 257, 10
    CONTROL "", IDC_PROCESSPROGRESS, "msctls_progress32", PBS_SMOOTH | WS_CHILD | WS_VISIBLE | WS_BORDER, 20, 120, 277, 8
END

IDD_FINISHPAGE DIALOGEX 0, 0, 317, 193
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Käynnistetään tietokone uudelleen", IDC_FINISHTITLE, 115, 8, 195, 24
    LTEXT "ReactOSin asennuksen ensimmäinen vaihe on suoritettu onnistuneesti.", IDC_STATIC, 115, 40, 195, 24
    // The following text can be replaced by IDS_FINISH_NO_REBOOT at runtime;
    // please ensure it can hold in the text control!
    LTEXT "Asennus käynnistää nyt tietokoneen uudelleen asennuksen toista vaihetta varten.\n\nTietokone käynnistyy automaattisesti uudelleen 15 sekunnin kuluttua tai kun valitset Käynnistä uudelleen.", IDC_FINISHTEXT, 115, 78, 195, 56
    CONTROL "", IDC_RESTART_PROGRESS, "msctls_progress32", PBS_SMOOTH | WS_CHILD | WS_VISIBLE | WS_BORDER, 115, 135, 188, 12
END

IDD_ABORTPAGE DIALOGEX 0, 0, 317, 193
STYLE DS_SHELLFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "ReactOS-asennus"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "ReactOS-asennus päättyi ennenaikaisesti", IDC_FINISHTITLE, 115, 8, 195, 24
    LTEXT "ReactOSin asennuksen ensimmäinen vaihe päättyi ennenaikaisesti virheen vuoksi tai siksi, että peruit sen.\n\nVoit suorittaa asennusohjelman myöhemmin uudelleen asentaaksesi tai päivittääksesi ReactOSin.", IDC_STATIC, 115, 40, 195, 48
    // The following text can be replaced by IDS_ABORT_NO_REBOOT at runtime;
    // please ensure it can hold in the text control!
    LTEXT "Tietokone käynnistyy automaattisesti uudelleen 15 sekunnin kuluttua tai kun valitset Käynnistä uudelleen.", IDC_FINISHTEXT, 115, 110, 195, 24
    CONTROL "", IDC_RESTART_PROGRESS, "msctls_progress32", PBS_SMOOTH | WS_CHILD | WS_VISIBLE | WS_BORDER, 115, 135, 188, 12
END

